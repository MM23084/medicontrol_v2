<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Detalle de Cita"
            android:textAlignment="center"
            android:textColor="@color/medicalBlueDark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:padding="12dp"
            android:textSize="16sp" />

        <!-- ACCIONES MÉDICO -->

        <Button
            android:id="@+id/btnAceptar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Aceptar cita"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/medicalBlueDark" />

        <Button
            android:id="@+id/btnRechazar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Rechazar cita"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/medicalBlueDark" />

        <Button
            android:id="@+id/btnFinalizar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Finalizar cita"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/medicalBlueDark" />

        <!-- ACCIONES PACIENTE -->

        <Button
            android:id="@+id/btnCancelar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Cancelar cita"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/medicalBlueDark" />

        <Button
            android:id="@+id/btnEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Editar cita"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/medicalBlueDark" />

        <Button
            android:id="@+id/btnEliminar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Eliminar cita"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/medicalBlueDark" />

        <Button
            android:id="@+id/btnCerrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cerrar"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/medicalBlueDark" />

    </LinearLayout>

</ScrollView>