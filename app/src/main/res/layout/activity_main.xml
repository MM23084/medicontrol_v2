<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/medicalBackground"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:id="@+id/contenedor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:animationCache="true"
        android:clickable="true"
        android:defaultFocusHighlightEnabled="true"
        android:focusableInTouchMode="true"
        android:focusedByDefault="true" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animationCache="false"
        android:background="@color/medicalGray"
        app:backgroundTint="@color/medicalWhite"
        app:itemIconTint="@color/medicalBlueDark"
        app:itemTextColor="@color/medicalBlueDark"
        app:labelVisibilityMode="selected"
        app:menu="@menu/bottom_menu"
        app:itemActiveIndicatorStyle="@style/CustomIndicator"/>

</LinearLayout>
